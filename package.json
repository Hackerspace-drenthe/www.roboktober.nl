{
  "name": "roboktober-monorepo",
  "private": true,
  "scripts": {
    "dev": "npm run dev:kill-ports && npx concurrently -k -n api,frontend -c \"#f59e0b,#06b6d4\" \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:8010": "npm run dev:kill-ports && npx concurrently -k -n api,frontend -c \"#f59e0b,#06b6d4\" \"npm run dev:api:8010\" \"npm run dev:frontend:8010\"",
    "dev:kill-ports": "sh -c 'fuser -k 8000/tcp 8010/tcp 5173/tcp 5174/tcp 5175/tcp >/dev/null 2>&1 || true'",
    "dev:api": "cd roboktober-api/public && php -d upload_max_filesize=100M -d post_max_size=104M -S 127.0.0.1:8000 ../vendor/laravel/framework/src/Illuminate/Foundation/resources/server.php",
    "dev:api:8010": "cd roboktober-api/public && php -d upload_max_filesize=100M -d post_max_size=104M -S 127.0.0.1:8010 ../vendor/laravel/framework/src/Illuminate/Foundation/resources/server.php",
    "dev:frontend": "cd roboktober-frontend && VITE_API_PROXY_TARGET=http://localhost:8000 npm run dev -- --host 127.0.0.1 --port 5173 --strictPort",
    "dev:frontend:8010": "cd roboktober-frontend && VITE_API_PROXY_TARGET=http://localhost:8010 npm run dev -- --host 127.0.0.1 --port 5173 --strictPort"
  }
}
