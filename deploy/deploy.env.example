# Copy this file to deploy/deploy.env and fill in your real values.
# The wrapper scripts deploy/deploy-staging.sh and deploy/deploy-production.sh
# will load this file automatically.

# ---------- Shared defaults (optional) ----------
# DEPLOY_SSH_PORT=22
# DEPLOY_REPO_DIR=/var/www/www.roboktober.nl
# DEPLOY_BRANCH=master
# DEPLOY_RUN_MIGRATIONS=true
# DEPLOY_BUILD_FRONTEND=false
# DEPLOY_DRY_RUN=false

# ---------- Staging ----------
STAGING_HOST=rein@192.168.1.10
STAGING_SSH_PORT=22
STAGING_REPO_DIR=/var/www/www.roboktober.nl
STAGING_BRANCH=master
STAGING_RUN_MIGRATIONS=true
STAGING_BUILD_FRONTEND=false
# STAGING_PHP_BIN=php8.4
# STAGING_COMPOSER_BIN=/usr/bin/composer

# ---------- Production ----------
PRODUCTION_HOST=rein@192.168.1.10
PRODUCTION_SSH_PORT=22
PRODUCTION_REPO_DIR=/var/www/www.roboktober.nl
PRODUCTION_BRANCH=master
PRODUCTION_RUN_MIGRATIONS=true
PRODUCTION_BUILD_FRONTEND=false
# PRODUCTION_CONFIRM=deploy-production
# PRODUCTION_PHP_BIN=php8.4
# PRODUCTION_COMPOSER_BIN=/usr/bin/composer
